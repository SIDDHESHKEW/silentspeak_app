# =====================================================
# SilentSpeak Project .gitignore
# Python Backend + React Frontend
# =====================================================

# -------------------------
# Python
# -------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Python virtual environments
venv/
env/
.venv/

# Python build
build/
dist/
*.egg-info/

# Logs
*.log

# Environment variables
.env

# Jupyter notebooks
.ipynb_checkpoints/

# -------------------------
# TensorFlow / Model Files
# -------------------------
# (remove this if you WANT the model in repo)

*.h5
*.keras
*.ckpt
*.pb

# -------------------------
# Whisper models
# -------------------------
# whisper downloads model cache locally

~/.cache/whisper/

# -------------------------
# OpenCV temp files
# -------------------------
*.avi
*.mp4
*.wav

# -------------------------
# FastAPI
# -------------------------
*.db
*.sqlite3

# -------------------------
# Node / React
# -------------------------
frontend/node_modules/

frontend/dist/
frontend/build/

# Vite
frontend/.vite/

# Node logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------
# OS files
# -------------------------
.DS_Store
Thumbs.db

# -------------------------
# VS Code
# -------------------------
.vscode/

# -------------------------
# Temporary folders
# -------------------------
tmp/
temp/
.cache/